# Stripe (server — never expose sk_ to the client)
# Use sk_test_… in test mode; sk_live_… in production.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Recurring monthly Price IDs (BRL) — from Stripe Dashboard (price_…)
# You can list multiple prices per plan (comma-separated) if Stripe recreates prices.
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_PLUS=price_...
STRIPE_PRICE_ULTRA=price_...

# Optional fallback: Product IDs (prod_…) — same for all prices of that product (Payment Links)
# STRIPE_PRODUCT_PRO=prod_...
# STRIPE_PRODUCT_PLUS=prod_...
# STRIPE_PRODUCT_ULTRA=prod_...
