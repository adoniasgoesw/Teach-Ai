# Google Cloud Text-to-Speech (service account JSON)
# Render/Netlify backend: paste minified JSON in GOOGLE_TTS_CREDENTIALS_JSON, or base64:
#   PowerShell: [Convert]::ToBase64String([IO.File]::ReadAllBytes("key.json"))  → GOOGLE_TTS_CREDENTIALS_JSON_B64
# Enable "Cloud Text-to-Speech API" on the GCP project.
# GOOGLE_TTS_CREDENTIALS_JSON={"type":"service_account",...}
# GOOGLE_TTS_CREDENTIALS_JSON_B64=...
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/key.json   # local dev only if file exists on server

# Stripe (server — never expose sk_ to the client)
# Use sk_test_… in test mode; sk_live_… in production.
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Recurring monthly Price IDs (BRL) — from Stripe Dashboard (price_…)
# You can list multiple prices per plan (comma-separated) if Stripe recreates prices.
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_PLUS=price_...
STRIPE_PRICE_ULTRA=price_...

# Optional fallback: Product IDs (prod_…) — same for all prices of that product (Payment Links)
# STRIPE_PRODUCT_PRO=prod_...
# STRIPE_PRODUCT_PLUS=prod_...
# STRIPE_PRODUCT_ULTRA=prod_...
